# File: .env.example
# Copy to .env and fill in values

# ─── Required ───
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SEED_PHRASE=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# ─── Optional (have sensible defaults) ───
RPC_URL=http://localhost:8545
CHAIN_ID=42161
CYCLE_INTERVAL_MS=8000
MAX_LEVERAGE=3.0
MIN_HEALTH_FACTOR=1.3
MIN_CONFIDENCE=0.6
INITIAL_COLLATERAL_WEI=5000000000000000000
PROFIT_DISBURSE_PCT=0.10
TREASURY_ADDRESS=0x000000000000000000000000000000000000dEaD
MAX_CYCLES=100
USE_MOCK_LLM=false

# ─── For Anvil fork ───
ARB_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
WALLET_ADDRESS=0xYOUR_WDK_DERIVED_ADDRESS
